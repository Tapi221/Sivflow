# Local Postgres
# Windows/macOS host processから接続する場合:
DATABASE_URL=postgresql://sivflow:sivflow@localhost:5432/sivflow

# Dockerコンテナ内のNode.jsから接続する場合は host を postgres にする:
# DATABASE_URL=postgresql://sivflow:sivflow@postgres:5432/sivflow

# Local Redis
REDIS_URL=redis://localhost:6379

# Firebase Functions secrets are still managed with Firebase Secret Manager.
# Existing secrets:
# - GOOGLE_OAUTH_CLIENT_ID
# - GOOGLE_OAUTH_CLIENT_SECRET
# - GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY
