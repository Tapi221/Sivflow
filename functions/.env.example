# Local Postgres
# 認証情報は各自のローカルPostgreSQL設定に合わせてください。
DATABASE_URL=postgresql://sivflow@localhost:5432/sivflow

# Local Redis
REDIS_URL=redis://localhost:6379

# Firebase Functions secrets are still managed with Firebase Secret Manager.
# Existing secrets:
# - GOOGLE_OAUTH_CLIENT_ID
# - GOOGLE_OAUTH_CLIENT_SECRET
# - GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY
