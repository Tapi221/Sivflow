{
  "name": "flashcard-master-functions",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": {
      "types": "./src/*",
      "default": "./lib/*"
    }
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "manifest": "node scripts/generateManifest.mjs",
    "deploy": "npm run build && firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.1"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
