rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function legacyImageOwnedByAuthUid(data) {
      return data != null &&
        data.userId is string &&
        data.userId == request.auth.uid;
    }

    function isPptxConversionOwnedBy(userId, conversionId, data) {
      return data != null &&
        data.uid is string &&
        data.uid == userId &&
        data.docId is string &&
        data.docId == conversionId;
    }

    function isPptxSourcePathForDoc(userId, conversionId, sourcePath) {
      return sourcePath is string &&
        sourcePath.matches("^users/" + userId + "/documents/" + conversionId + "/.*$");
    }

    function canCreatePptxConversion(userId, conversionId) {
      return isAuthenticated() &&
        isOwner(userId) &&
        request.resource.data.keys().hasOnly([
          "docId",
          "uid",
          "sourceStoragePath",
          "status",
          "createdAt",
          "updatedAt",
          "requestOrigin"
        ]) &&
        isPptxConversionOwnedBy(userId, conversionId, request.resource.data) &&
        request.resource.data.status == "queued" &&
        isPptxSourcePathForDoc(userId, conversionId, request.resource.data.sourceStoragePath);
    }

    function canRetryPptxConversion(userId, conversionId) {
      return isAuthenticated() &&
        isOwner(userId) &&
        isPptxConversionOwnedBy(userId, conversionId, resource.data) &&
        isPptxConversionOwnedBy(userId, conversionId, request.resource.data) &&
        request.resource.data.status == "queued" &&
        request.resource.data.sourceStoragePath == resource.data.sourceStoragePath &&
        request.resource.data.manifestPath == resource.data.manifestPath &&
        request.resource.data.fallbackPdfPath == resource.data.fallbackPdfPath &&
        request.resource.data.slideCount == resource.data.slideCount &&
        request.resource.data.errorMessage == resource.data.errorMessage &&
        request.resource.data.processingStartedAt == resource.data.processingStartedAt &&
        request.resource.data.convertedAt == resource.data.convertedAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt",
          "createdAt",
          "requestOrigin"
        ]);
    }
    
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      match /folders/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /cards/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /cardSets/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /tags/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /cardRelations/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /projectMaps/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /uploads/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /images/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /assets/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /documents/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
      match /pptxConversions/{id} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if canCreatePptxConversion(userId, id);
        allow update: if canRetryPptxConversion(userId, id);
        allow delete: if false;
      }
      match /securityLogs/{id} { allow read, write: if isAuthenticated() && isOwner(userId); }
    }

    match /images/{imageId} {
      allow read: if isAuthenticated() && legacyImageOwnedByAuthUid(resource.data);
      allow create, update, delete: if false;
    }
    
    match /userSettings/{settingId} {
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /userStats/{statId} {
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
    }
    
    match /folders/{folderId} {
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /cards/{cardId} {
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /studyLogs/{logId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    match /trainingLogs/{logId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    match /deletedItems/{itemId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /shareLinks/{shareLinkId} {
      allow read: if isAuthenticated() && 
        resource.data.ownerUserId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.ownerUserId == request.auth.uid;
      allow read: if resource.data.isActive == true;
    }
    
    match /sharedFolders/{sharedFolderId} {
      allow read: if isAuthenticated() && 
        (resource.data.originalOwnerUserId == request.auth.uid ||
         resource.data.importedByUserId == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.importedByUserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.importedByUserId == request.auth.uid;
    }
    
    match /loginHistory/{historyId} {
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }

    match /sync_locks/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /sync_metadata/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      match /devices/{deviceId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }
  }
}