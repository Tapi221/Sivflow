{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vitest/globals", "node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "#src/*": ["functions/src/*"],
      "@core/*": ["packages/core/src/*"],
      "@platform/*": ["packages/platform/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"],
      "@security-contract": ["functions/src/security/contract.ts"]
    }
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "functions/src/**/*.ts",
    "shared/**/*.ts",
    "packages/core/src/**/*.ts",
    "packages/platform/src/**/*.ts"
  ]
}
