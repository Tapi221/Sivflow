{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["vitest/globals", "node", "vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@security-contract": ["functions/src/security/contract.ts"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "functions/src/**/*.ts",
    "constants/**/*.ts",
    "config/**/*.ts"
  ]
}
