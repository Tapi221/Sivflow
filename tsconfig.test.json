{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "node", "vite/client"],
    "paths": {
      "@/services/localDB": ["src/services/localdb/index.ts"],
      "@/services/firebase": ["src/infrastructure/firebase/client.ts"],
      "@platform/*": ["packages/platform/src/*"],
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@shared/*": ["shared/*"],
      "@security-contract": ["functions/src/security/contract.ts"]
    }
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "functions/src/**/*.ts",
    "constants/**/*.ts",
    "shared/**/*.ts",
    "packages/platform/src/**/*.ts"
  ]
}