{
  "manifest_version": 3,
  "name": "ChatGPT Approval Hub",
  "version": "0.1.0",
  "description": "複数のChatGPTタブに出ている承認ダイアログを一覧化して、選択したものを承認します。",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT Approval Hub",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
