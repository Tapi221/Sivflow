{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: check app",
      "type": "shell",
      "command": "npm exec tsc -- -p tsconfig.app.json --noEmit --pretty false",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "TypeScript: check node",
      "type": "shell",
      "command": "npm exec tsc -- -p tsconfig.node.json --noEmit --pretty false",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "TypeScript: check electron",
      "type": "shell",
      "command": "npm exec tsc -- -p tsconfig.electron.json --noEmit --pretty false",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "TypeScript: check tests",
      "type": "shell",
      "command": "npm exec tsc -- -p tsconfig.test.json --noEmit --pretty false",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "TypeScript: check mobile",
      "type": "shell",
      "command": "npm --prefix apps/mobile run typecheck",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "ESLint: lint workspace",
      "type": "shell",
      "command": "npm exec eslint -- .",
      "group": "build",
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "Build: web",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "problemMatcher": [
        "$tsc",
        {
          "owner": "vite",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^(.+)\\((\\d+):(\\d+)\\):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        },
        {
          "owner": "vite-rollup",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^\\[vite\\]: Rollup failed to resolve import .+ from \"(.+)\"\\.$",
            "file": 1,
            "message": 0
          }
        }
      ]
    },
    {
      "label": "Build: electron",
      "type": "shell",
      "command": "npm run electron:build",
      "group": "build",
      "problemMatcher": [
        "$tsc",
        {
          "owner": "esbuild",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^\\s*(.+):(\\d+):(\\d+):\\s*(?:ERROR|error):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "Problems: check workspace",
      "dependsOn": [
        "TypeScript: check app",
        "TypeScript: check node",
        "TypeScript: check electron",
        "TypeScript: check tests",
        "TypeScript: check mobile",
        "ESLint: lint workspace",
        "Build: web",
        "Build: electron"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
