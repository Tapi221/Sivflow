# ローカル libSQL を使う場合は未設定でも file:./dev-turso.db が使われます。
# TURSO_DATABASE_URL="file:./dev-turso.db"

# リモート Turso を使う場合はこちらを設定してください。
# TURSO_DATABASE_URL="libsql://your-database.turso.io"
# TURSO_AUTH_TOKEN="replace-with-your-token"

# REDIS_SERVER_HOST=localhost
# COPILOT_FAL_API_KEY=replace-with-your-key
# COPILOT_OPENAI_API_KEY=replace-with-your-key
# COPILOT_PERPLEXITY_API_KEY=replace-with-your-key

# MAILER_HOST=127.0.0.1
# MAILER_PORT=1025
# MAILER_SERVERNAME="mail.example.com"
# MAILER_SENDER="noreply@toeverything.info"
# MAILER_USER="noreply@toeverything.info"
# MAILER_PASSWORD="affine"
# MAILER_SECURE=false

# AFFINE_INDEXER_ENABLED=true
