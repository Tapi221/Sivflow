{
  "name": "@affine/web",
  "version": "0.26.3",
  "description": "Sivflow Web application",
  "private": true,
  "browser": "src/index.tsx",
  "scripts": {
    "prebuild": "npm --prefix ../../../.. --workspace @affine/templates run build",
    "predev": "npm --prefix ../../../.. --workspace @affine/templates run build",
    "build": "node ../../../../scripts/build-cache.mjs --name affine-web --root ../../../.. --cwd packages/frontend/apps/web --input package.json --input package-lock.json --input packages/frontend --input packages/common --input blocksuite --output packages/frontend/apps/web/dist -- npm run build:raw",
    "build:raw": "node --max-old-space-size=4096 ../../../../node_modules/vite/bin/vite.js build",
    "dev": "vite"
  },
  "dependencies": {
    "@affine/component": "*",
    "@affine/core": "*",
    "@affine/env": "*",
    "@affine/nbstore": "*",
    "@affine/track": "*",
    "@emotion/react": "^11.14.0",
    "@toeverything/infra": "*",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
