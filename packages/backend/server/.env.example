# ローカルPostgreSQLを使う場合
# 認証情報は各自のローカルPostgreSQL設定に合わせてください。
DATABASE_URL="postgresql://sivflow@127.0.0.1:5432/sivflow?schema=public"

# Redisを使う場合
REDIS_SERVER_HOST=localhost
REDIS_SERVER_PORT=6379

