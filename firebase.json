{
  "firestore": {
    "database": "(default)",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "packages/frontend/apps/web/dist",
    "predeploy": [
      "npm run build:deploy"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api",
        "run": {
          "serviceId": "sivflow-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "sivflow-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/graphql",
        "run": {
          "serviceId": "sivflow-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/oauth/**",
        "run": {
          "serviceId": "sivflow-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/socket.io/**",
        "run": {
          "serviceId": "sivflow-api",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|jpg|jpeg|png|gif|webp|svg|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}
