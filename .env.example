# Copy this file to `.env.local` (or `.env`) and fill in the placeholders.
# Never commit real secrets. `.env` / `.env.*` are ignored by git.

# --- Firebase (Web / Vite) ---
VITE_FIREBASE_API_KEY=__REPLACE_ME__
VITE_FIREBASE_AUTH_DOMAIN=__REPLACE_ME__
VITE_FIREBASE_PROJECT_ID=__REPLACE_ME__
VITE_FIREBASE_STORAGE_BUCKET=__REPLACE_ME__
VITE_FIREBASE_MESSAGING_SENDER_ID=__REPLACE_ME__
VITE_FIREBASE_APP_ID=__REPLACE_ME__

# Use Firebase emulators when running locally (optional)
VITE_USE_FIREBASE_EMULATOR=false

# --- Google OAuth (Web + Desktop PKCE) ---
# Google Cloud Console で「アプリケーションの種類: ウェブ アプリケーション」の
# OAuth 2.0 クライアント ID を1つだけ作成し、その Client ID を入れてください。
VITE_GOOGLE_OAUTH_CLIENT_ID=__REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID__
VITE_DESKTOP_GOOGLE_OAUTH_SCOPE="openid email profile"
# Tauri uses the loopback redirect baked into constants/desktop/app.ts.
# Keep this in sync when set locally: http://127.0.0.1:42813
VITE_DESKTOP_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:42813

# --- Web Google OAuth (server-side token storage) ---
# Error 400: origin_mismatch / redirect_uri_mismatch が出る場合は、
# Google Cloud Console のこの OAuth クライアント ID に、実際にアプリを開いている
# URL の origin（window.location.origin）を完全一致で登録してください。
# 「承認済みの JavaScript 生成元」には Web の origin を登録します。
# 「承認済みのリダイレクト URI」には Web の origin と desktop loopback を登録します。
# Web Calendar OAuth は redirect_uri に window.location.origin を使うため、Web の
# リダイレクト URI は path や末尾スラッシュを含めません。
# 例:
#   http://localhost:5173       # npm run dev:web
#   http://127.0.0.1:5173       # 127.0.0.1 で開く場合
#   http://localhost:5000       # Firebase Hosting emulator
#   https://<project-id>.web.app
#   https://<project-id>.firebaseapp.com
#   https://<custom-domain>
#   http://127.0.0.1:42813      # Tauri desktop loopback redirect

# Web / 非 Desktop では refresh token を localStorage に保存しないため、
# Cloud Functions + Firestore の暗号化保存を使います。
# 本番ビルドではコード側で server tokens を強制します。
# ローカル検証などで従来の GIS access token のみに戻す場合だけ false を指定してください。
VITE_GOOGLE_OAUTH_SERVER_TOKENS=true

# Functions secrets (set via Firebase CLI, not in .env)
# firebase functions:secrets:set GOOGLE_OAUTH_CLIENT_ID
# firebase functions:secrets:set GOOGLE_OAUTH_CLIENT_SECRET
# firebase functions:secrets:set GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY は 32bytes を base64 化した値
