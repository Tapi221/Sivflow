# Copy this file to `.env.local` (or `.env`) and fill in secrets locally.
# Never commit real secrets. `.env` / `.env.*` are ignored by git.

# --- Firebase (Web / Vite) ---
# These Firebase web config values are public client config values.
VITE_FIREBASE_API_KEY=AIzaSyBDCKB3H_JgfnoZy9BpJYzijZCKf3oSIpA
VITE_FIREBASE_AUTH_DOMAIN=anki-70f73.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=anki-70f73
VITE_FIREBASE_STORAGE_BUCKET=anki-70f73.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=597522813476
VITE_FIREBASE_APP_ID=1:597522813476:web:3b4eb1fafa9c4d388e3eb1

# Use Firebase emulators when running locally (optional)
VITE_USE_FIREBASE_EMULATOR=false

# --- Desktop (Electron) Google OAuth (PKCE) ---
# These are used in the renderer (Vite) and main process (Electron).
VITE_DESKTOP_GOOGLE_OAUTH_CLIENT_ID=597522813476-hc08flnp5jg0h2erl8js45j2d1hu0fpv.apps.googleusercontent.com
VITE_DESKTOP_GOOGLE_OAUTH_SCOPE="openid email profile"
VITE_DESKTOP_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:42813/auth/google/callback

# Desktop main-process secret. Keep the real value only in `.env.local` / `.env`.
GOOGLE_OAUTH_WEB_CLIENT_SECRET=__REPLACE_ME_LOCALLY__

# --- Web Google OAuth / server-stored refresh tokens ---
# false の場合、Web 版は従来の GIS token flow を使います。
# true にする場合は、Web OAuth Client ID と Firebase Functions secrets も設定してください。
VITE_GOOGLE_OAUTH_SERVER_TOKENS=false

# Web 版で server-stored refresh tokens を使う場合のみ設定します。
# Google Cloud Console の「OAuth 2.0 クライアント ID」で種類「ウェブアプリケーション」のもの。
VITE_WEB_GOOGLE_OAUTH_CLIENT_ID=__REPLACE_WITH_WEB_OAUTH_CLIENT_ID__

# --- Firebase Functions secrets ---
# These are NOT read from `.env.example` during deploy.
# Set them in Cloud Secret Manager through Firebase CLI when prompted, or with:
# firebase functions:secrets:set GOOGLE_OAUTH_WEB_CLIENT_ID
# firebase functions:secrets:set GOOGLE_OAUTH_WEB_CLIENT_SECRET
# firebase functions:secrets:set GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY
#
# GOOGLE_OAUTH_WEB_CLIENT_ID:
#   Web OAuth Client ID used by exchangeGoogleCalendarCode.
# GOOGLE_OAUTH_WEB_CLIENT_SECRET:
#   Web OAuth Client Secret. Do not commit the real value.
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY:
#   Base64 encoded 32-byte key. Generate with PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
