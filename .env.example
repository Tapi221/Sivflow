# Copy this file to `.env.local` (or `.env`) and fill in the placeholders.
# Never commit real secrets. `.env` / `.env.*` are ignored by git.

# --- Firebase (Web / Vite) ---
VITE_FIREBASE_API_KEY=__REPLACE_ME__
VITE_FIREBASE_AUTH_DOMAIN=__REPLACE_ME__
VITE_FIREBASE_PROJECT_ID=__REPLACE_ME__
VITE_FIREBASE_STORAGE_BUCKET=__REPLACE_ME__
VITE_FIREBASE_MESSAGING_SENDER_ID=__REPLACE_ME__
VITE_FIREBASE_APP_ID=__REPLACE_ME__

# Use Firebase emulators when running locally (optional)
VITE_USE_FIREBASE_EMULATOR=false

# --- Desktop (Electron) Google OAuth (PKCE) ---
# These are used in the renderer (Vite) and main process (Electron).
VITE_DESKTOP_GOOGLE_OAUTH_CLIENT_ID=__REPLACE_ME__
VITE_DESKTOP_GOOGLE_OAUTH_SCOPE="openid email profile"
# Must match the redirect URI baked into the desktop bridge.
VITE_DESKTOP_GOOGLE_OAUTH_REDIRECT_URI=__REPLACE_ME__

# --- Web Google OAuth (GIS Token Client) ---
# Google Cloud Console の「OAuth 2.0 クライアント ID」で種類「ウェブアプリケーション」のもの。
# Firebase Auth で使用している Web クライアント ID と同じで問題ありません。
VITE_WEB_GOOGLE_OAUTH_CLIENT_ID=__REPLACE_ME__

# Main process secret (DO NOT expose to renderer)
GOOGLE_OAUTH_WEB_CLIENT_SECRET=__REPLACE_ME__

VITE_GOOGLE_OAUTH_SERVER_TOKENS=false

# Functions secrets (set via Firebase CLI, not in .env)
# firebase functions:secrets:set GOOGLE_OAUTH_WEB_CLIENT_ID
# firebase functions:secrets:set GOOGLE_OAUTH_WEB_CLIENT_SECRET
# firebase functions:secrets:set GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY は 32bytes を base64 化した値
