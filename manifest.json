{
  "manifest_version": 3,
  "name": "ChatGPT Approval Hub",
  "version": "0.1.3",
  "description": "複数のChatGPTタブに出ている承認ダイアログを一覧化して、選択したものを承認します。",
  "permissions": ["tabs", "scripting", "storage", "alarms"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background-launcher.js"
  },
  "action": {
    "default_title": "ChatGPT Approval Hub"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js", "chat-delete.js", "delete-button-visibility.js"],
      "run_at": "document_idle"
    }
  ]
}
