import { db } from './firebase';
import { LocalDB } from './localDB';
import { collection, getDocs, query, where, writeBatch, Timestamp, doc, getDoc } from 'firebase/firestore';
import type { Folder, Card, User, UserSettings, UserStats } from '../types';

type SyncableCollection = 'users' | 'userSettings' | 'folders' | 'cards' | 'userStats';

/**
 * FirestoreとローカルDB (Dexie) 間の差分同期を管理するサービスクラス。
 */
export class SyncService {
  private userId: string;
  private localDB: LocalDB;

  constructor(userId: string) {
    if (!userId) {
      throw new Error('SyncService requires a user ID.');
    }
    this.userId = userId;
    // ユーザーごとにLocalDBインスタンスを作成
    this.localDB = new LocalDB(userId);
  }

  /**
   * クラウドからの変更をプルし、ローカルDBに適用します。
   * @returns 同期が成功したかどうか
   */
  async pullChanges(): Promise<boolean> {
    const lastSyncTime = await this.localDB.getLastSyncTime(this.userId);
    console.log(`[Sync] Pulling changes since: ${lastSyncTime?.toISOString()}`);

    try {
      // 各コレクションから安全にデータを取得
      const serverChanges = {
        users: await this.fetchUpdatedDocsSafe('users', lastSyncTime),
        userSettings: await this.fetchUpdatedDocsSafe('userSettings', lastSyncTime),
        folders: await this.fetchUpdatedDocsSafe('folders', lastSyncTime),
        cards: await this.fetchUpdatedDocsSafe('cards', lastSyncTime),
        userStats: await this.fetchUserStats(),
      };

      // 取得したデータをローカルDBに一括で適用
      await this.localDB.bulkUpsert('users', serverChanges.users);
      await this.localDB.bulkUpsert('userSettings', serverChanges.userSettings);
      await this.localDB.bulkUpsert('folders', serverChanges.folders);
      await this.localDB.bulkUpsert('cards', serverChanges.cards);
      await this.localDB.bulkUpsert('userStats', serverChanges.userStats);

      // 最終同期時刻を更新
      await this.localDB.updateLastSyncTime(this.userId, new Date());
      console.log('[Sync] Pull completed successfully.');
      return true;
    } catch (error) {
      console.error('[Sync] Error pulling changes from Firestore:', error);
      return false;
    }
  }

  /**
   * 指定されたコレクションから、最終同期時刻以降に更新されたドキュメントを取得します（エラーハンドリング付き）。
   * @param collectionName 同期するコレクション名
   * @param lastSyncTime 最終同期時刻
   */
  private async fetchUpdatedDocsSafe<T>(collectionName: SyncableCollection, lastSyncTime: Date | null): Promise<T[]> {
    try {
      // 'users' と 'userSettings' は1ユーザー1ドキュメントなので、直接ドキュメントを取得
      if (collectionName === 'users' || collectionName === 'userSettings') {
        const docRef = doc(db, collectionName, this.userId);
        const snapshot = await getDoc(docRef);
        if (snapshot.exists()) {
          return [{ id: snapshot.id, ...snapshot.data() } as T];
        }
        return [];
      }

      // lastSyncTimeがない場合（初回同期など）、すべてのドキュメントを取得
      const collRef = collection(db, collectionName);
      const q = lastSyncTime
        ? query(collRef, where('userId', '==', this.userId), where('updatedAt', '>', Timestamp.fromDate(lastSyncTime)))
        : query(collRef, where('userId', '==', this.userId));

      const snapshot = await getDocs(q);
      return snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as T));
    } catch (error: any) {
      // 権限不足の場合はログに出力して空配列を返す
      if (error?.code === 'permission-denied') {
        console.warn(`[Sync] Permission denied for collection "${collectionName}". Skipping...`);
        return [];
      }
      throw error;
    }
  }

  /**
   * 指定されたコレクションから、最終同期時刻以降に更新されたドキュメントを取得します。
   * @param collectionName 同期するコレクション名
   * @param lastSyncTime 最終同期時刻
   */
  private async fetchUpdatedDocs<T>(collectionName: SyncableCollection, lastSyncTime: Date | null): Promise<T[]> {
    // lastSyncTimeがない場合（初回同期など）、すべてのドキュメントを取得
    const collRef = collection(db, collectionName);
    const q = lastSyncTime
      ? query(collRef, where('userId', '==', this.userId), where('updatedAt', '>', Timestamp.fromDate(lastSyncTime)))
      : query(collRef, where('userId', '==', this.userId));

    const snapshot = await getDocs(q);
    return snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as T));
  }

  /**
   * userStatsドキュメントを取得します。
   * userStatsは読み取り専用で、Cloud Functionsのみが書き込み可能です。
   */
  private async fetchUserStats(): Promise<UserStats[]> {
    try {
      const docRef = doc(db, 'userStats', this.userId);
      const snapshot = await getDoc(docRef);
      if (snapshot.exists()) {
        return [{ id: snapshot.id, ...snapshot.data() } as UserStats];
      }
      return [];
    } catch (error: any) {
      if (error?.code === 'permission-denied') {
        console.warn('[Sync] Permission denied for userStats. Skipping...');
        return [];
      }
      console.warn('[Sync] Failed to fetch userStats:', error);
      return [];
    }
  }
  
    /**
   * ローカルでの変更を検出し、Firestoreにプッシュします。
   * @returns 同期が成功したかどうか
   */
  async pushChanges(): Promise<boolean> {
    // Note: A more robust implementation would use a 'dirty' flag or a separate outbox table.
    // For this implementation, we assume that any local change also updates `updatedAt`.
    const lastSyncTime = await this.localDB.getLastSyncTime(this.userId);
    if (!lastSyncTime) {
      console.warn('[Sync] Cannot push changes without a last sync time. A pull is needed first.');
      return false;
    }
    console.log(`[Sync] Pushing local changes since: ${lastSyncTime.toISOString()}`);
    
    try {
        const batch = writeBatch(db);

        // 各テーブルからダーティなアイテム（ローカルで更新されたアイテム）を取得
        const dirtyFolders = await this.localDB.getDirtyItems('folders', lastSyncTime);
        const dirtyCards = await this.localDB.getDirtyItems('cards', lastSyncTime);
        // ... (add other tables like userSettings, userStats)

        // 同期が無効なフォルダのIDリストを取得
        const disabledSyncFolderIds = new Set(
            (await (this.localDB as any).folders.where({ cloudSyncEnabled: 'false' }).toArray()).map((f: any) => f.id)
        );

        // フォルダの変更をバッチに追加
        for (const folder of dirtyFolders) {
            if (folder.cloudSyncEnabled) {
              const docRef = doc(db, `users/${this.userId}/folders/${folder.id}`);
                batch.set(docRef, folder);
            }
        }

        // カードの変更をバッチに追加（同期が無効なフォルダのカードは除外）
        for (const card of dirtyCards) {
            const parentFolder = await this.localDB.folders.get(card.folderId);
            if (parentFolder?.cloudSyncEnabled) {
              const docRef = doc(db, `users/${this.userId}/cards/${card.id}`);
                batch.set(docRef, card);
            }
        }

        await batch.commit();
        console.log('[Sync] Push completed successfully.');
        return true;
    } catch (error) {
        console.error('[Sync] Error pushing changes to Firestore:', error);
        return false;
    }
  }


  /**
   * 初回ログイン時や新端末でのログイン時に、Firestoreから全データを取得してローカルDBを初期化します。
   */
  async performFullSync(): Promise<void> {
    console.log('[Sync] Performing full sync from Firestore...');
    try {
      // ローカルの既存データをクリア
      await this.localDB.clearAllData();

      // lastSyncTimeをnullにして全データをfetchする
      await this.pullChanges();
      
      console.log('[Sync] Full sync completed.');
    } catch (error) {
      console.error('[Sync] Error during full sync:', error);
    }
  }

  /**
   * プルとプッシュを順番に実行する標準的な同期プロセス。
   */
  async synchronize(): Promise<void> {
    console.log('[Sync] Starting synchronization process...');
    const pullSuccess = await this.pullChanges();
    if (pullSuccess) {
      await this.pushChanges();
    }
    console.log('[Sync] Synchronization process finished.');
  }
}
