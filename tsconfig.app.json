{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["packages/core/src/*"],
      "@platform/*": ["packages/platform/src/*"],
      "@web-renderer/*": ["nouse/web-renderer/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@/nouse/*": ["nouse/*"],
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["apps/web/src", "packages/core/src", "packages/platform/src", "src", "shared", "nouse/chip", "nouse/popover-menu"],
  "exclude": ["src/app/api/**", "src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
}
