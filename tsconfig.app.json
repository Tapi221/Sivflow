{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "paths": {
      "@/services/localDB": ["src/services/localdb/index.ts"],
      "@/services/firebase": ["src/infrastructure/firebase/client.ts"],
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"]
    }
  },
  "include": [
    "src",
    "constants"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
}
