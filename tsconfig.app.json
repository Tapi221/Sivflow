{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@security-contract": ["functions/src/security/contract.ts"],
      "@config/*": ["config/*"]
    }
  },
  "include": [
    "src",
    "constants",
    "config",
    "functions/src/security/contract.ts"
, "functions/src/gcal/Gcalwebhook .tsx"  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
}
