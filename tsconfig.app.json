{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": {
      "@/services/localDB": ["src/services/localdb/index.ts"],
      "@/services/firebase": ["src/infrastructure/firebase/client.ts"],
      "@/features/tab/Tab": ["src/pane.desktop/tab.desktopnative/Tab.ts"],
      "@core/*": ["packages/core/src/*"],
      "@platform/*": ["packages/platform/src/*"],
      "@web-renderer/*": ["packages/web-renderer/src/*"],
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": [
    "apps/web/src",
    "packages/web-renderer/src",
    "packages/core/src",
    "packages/platform/src",
    "src",
    "constants",
    "shared"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
}