{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": {
      "@/services/localDB": ["src/services/localdb/index.ts"],
      "@/services/firebase": ["src/infrastructure/firebase/client.ts"],
      "@/features/tab/Tab": ["src/pane.desktop/tab.desktopnative/Tab.ts"],
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": [
    "src",
    "constants",
    "shared",
    "apps/mobile/src/pane/schedule/schedule.year.mobilenative.tsx",
    "apps/mobile/src/pane/navigationbar/navigationbar.tsx"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
}