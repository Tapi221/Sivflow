{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../src/*"],
      "@core/*": ["../../packages/core/src/*"],
      "@mobile/*": ["src/*"],
      "@mobile-renderer/*": ["../../packages/mobile-renderer/src/*"],
      "@constants/*": ["../../constants/*"],
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": [
    "index.ts",
    "src",
    "../../packages/core/src",
    "../../packages/mobile-renderer/src",
    "../../src/pane.mobilenative",
    "../../src/integration/googlecalendar-integration/gcalSync.types.ts",
    "../../shared/i18n",
    "app.json"
  ]
}