{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sivflow",
  "version": "0.0.0",
  "identifier": "app.sivflow.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/dev/free-port.mjs 5173 && npm --prefix ../.. run dev:web",
    "beforeBuildCommand": "npm --prefix ../.. run build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sivflow",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "visible": true,
        "center": true,
        "backgroundColor": "#EEF3F6"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
