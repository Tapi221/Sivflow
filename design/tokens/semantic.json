{
  "color": {
    "background": {
      "app": "{color.neutral.0}",
      "sidebar": "#ececee",
      "sidebarActive": "#f7f7f8",
      "floating": "rgba(255, 255, 255, 0.9)",
      "code": "{color.code.background}"
    },
    "border": {
      "default": "#d7d9de",
      "floating": "rgba(215, 217, 222, 0.82)",
      "strong": "#c7cad1"
    },
    "text": {
      "primary": "#2f3640",
      "secondary": "#6f7681",
      "strong": "#202734",
      "placeholder": "#939aa4",
      "onPrimary": "{color.neutral.0}"
    },
    "action": {
      "primary": "#3f5f90",
      "primaryHover": "#2f4f83",
      "primarySoft": "#edf2fa",
      "accent": "#2f4f83"
    },
    "interactive": {
      "selectedSubtle": "#f1f4f8",
      "selectedAccent": "#2f4f83",
      "columnSelectedSubtle": "rgba(47, 79, 131, 0.08)",
      "columnSelectedAccent": "#223b62"
    },
    "status": {
      "danger": "{color.status.danger}",
      "warning": "{color.status.warning}",
      "success": "{color.status.success}",
      "info": "{color.status.info}"
    }
  },
  "spacing": {
    "controlHeight": 36,
    "controlHeightLarge": 40,
    "panelWidth": 320,
    "menuMinWidth": 128,
    "safeTopOffsetBase": "{spacing.2}",
    "safeBottomPaddingBase": "{spacing.20}"
  },
  "radius": {
    "control": "{radius.md}",
    "card": "{radius.xl}",
    "flashcard": "{radius.lg}",
    "dialog": "{radius.floating}",
    "panel": "{radius.2xl}",
    "hero": "{radius.3xl}",
    "pill": "{radius.pill}"
  },
  "typography": {
    "ui": "{typography.fontFamily.ui}",
    "content": "{typography.fontFamily.content}",
    "numeric": "{typography.fontFamily.numeric}",
    "code": "{typography.fontFamily.code}"
  },
  "elevation": {
    "controlInset": "{elevation.shadow.concave}",
    "controlRaised": "{elevation.shadow.convex}",
    "floating": "{elevation.shadow.floating}",
    "panel": "{elevation.shadow.panel}",
    "card": "{elevation.shadow.card}",
    "cardHover": "{elevation.shadow.cardHover}"
  },
  "motion": {
    "interactive": "{motion.transition.interactive}",
    "screenEnter": "{motion.transition.screenEnter}",
    "progress": "{motion.transition.progress}"
  },
  "breadcrumb": {
    "height": 52,
    "gap": "{spacing.3}",
    "itemColor": "{semantic.color.text.secondary}",
    "itemHoverColor": "{semantic.color.text.strong}",
    "currentColor": "{semantic.color.text.primary}",
    "separatorColor": "{semantic.color.text.placeholder}",
    "itemMaxWidth": "min(46vw, 520px)"
  },
  "tag": {
    "fontSize": 12,
    "fontWeight": "{typography.fontWeight.medium}",
    "lineHeight": "16px",
    "paddingInline": "{spacing.2}",
    "paddingBlock": 1,
    "gap": "{spacing.1}",
    "radius": 20,
    "borderWidth": 0,
    "removeButtonSize": 16,
    "removeIconSize": 12,
    "focusRingWidth": 2
  }
}
