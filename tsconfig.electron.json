{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@constants/*": ["constants/*"],
      "@config/*": ["config/*"]
    },
    "rootDir": ".",
    "outDir": "dist-electron",
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "constants/**/*.ts"]
}
