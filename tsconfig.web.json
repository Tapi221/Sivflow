{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "lit/directives/guard.js": ["./tools/ts-shims/lit-cache-directive.d.ts"]
    },
    "types": ["vite/client", "build-config", "affine__env"],
    "typeRoots": ["./tools/@types", "./node_modules/@types", "./node_modules"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".firebase",
    "coverage",
    "tmp",
    "**/__tests__",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
