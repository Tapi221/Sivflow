{
  "name": "sivflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#src/*": "./functions/src/*"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run sync:app-icon && vite --config apps/web/vite.config.ts",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "dev:tauri": "npm run dev:desktop",
    "dev:mobile": "npm --prefix apps/mobile start",
    "build": "npm run build:web",
    "build:web": "npm run sync:app-icon && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build --config apps/web/vite.config.ts",
    "build:desktop": "npm run tauri:build",
    "build:tauri": "npm run tauri:build",
    "tauri:build": "npm --prefix apps/desktop run build",
    "mobile:install": "npm --prefix apps/mobile install",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "sync:app-icon": "node scripts/sync-app-icon.mjs",
    "verify:app-icon": "node scripts/sync-app-icon.mjs --check",
    "verify:icons": "node scripts/verify-icons-entry.mjs",
    "verify:no-emoji": "node scripts/verify/verify-no-symbols.mjs",
    "verify:no-compat-export-files": "node scripts/verify/verify-no-compat-export-files.mjs",
    "verify:type-only-imports": "node scripts/verify/verify-type-only-imports.mjs",
    "verify:blank-lines": "node scripts/verify/verify-repeated-blank-lines.mjs",
    "verify:short-hex-colors": "node scripts/verify/verify-short-hex-colors.mjs",
    "verify:nullish-fallback": "node scripts/verify/verify-nullish-fallback.mjs",
    "verify:jsx-child-spacing": "node scripts/verify/verify-jsx-child-spacing.mjs",
    "verify:sw": "node scripts/verify/verify-sw.mjs",
    "verify:module-constant-names": "node scripts/verify/verify-module-constant-names.mjs",
    "verify:const-arrow-functions": "node scripts/verify/verify-const-arrow-functions.mjs",
    "verify:pdf-zoom-constants": "node scripts/verify/verify-pdf-zoom-constants.mjs",
    "fix:no-compat-export-files": "node scripts/verify/fix-no-compat-export-files.mjs",
    "fix:type-only-imports": "node scripts/verify/fix-type-only-imports.mjs",
    "fix:const-arrow-functions": "node scripts/verify/fix-const-arrow-functions.mjs",
    "fix:blank-lines": "node scripts/verify/fix-repeated-blank-lines.mjs",
    "fix:short-hex-colors": "node scripts/verify/fix-short-hex-colors.mjs",
    "fix:nullish-fallback": "node scripts/verify/fix-nullish-fallback.mjs",
    "fix:jsx-child-spacing": "node scripts/verify/fix-jsx-child-spacing.mjs",
    "fix:known-lint-errors": "node scripts/verify/fix-known-lint-errors.mjs",
    "fix:alias-import-paths": "node scripts/fix-alias-import-paths.mjs",
    "fix:source-conventions": "npm run fix:type-only-imports && npm run fix:const-arrow-functions && npm run fix:blank-lines && npm run fix:short-hex-colors && npm run fix:nullish-fallback && npm run fix:known-lint-errors && npm run fix:no-compat-export-files && node scripts/fix-src-import-paths.mjs && npm run fix:alias-import-paths && node scripts/verify/fix-import-spacing.mjs && node scripts/verify/fix-source-order.mjs && node scripts/verify/fix-import-spacing.mjs && npm run fix:jsx-child-spacing && npm run fix:blank-lines",
    "verify:source-conventions": "npm run verify:no-compat-export-files && npm run verify:type-only-imports && node scripts/verify/verify-import-spacing.mjs && npm run verify:blank-lines && npm run verify:short-hex-colors && npm run verify:nullish-fallback && node scripts/verify/verify-source-conventions.mjs && npm run verify:jsx-child-spacing && npm run verify:const-arrow-functions && npm run verify:pdf-zoom-constants && npm run verify:module-constant-names",
    "watch:source-conventions": "node scripts/dev/watch-source-conventions.mjs",
    "watch:source-conventions:fix": "node scripts/dev/watch-source-conventions.mjs --fix",
    "fix:source-conventions:local-llm": "node scripts/dev/watch-source-conventions.mjs --fix --once",
    "sync:firebase-emulators": "npm exec tsx -- tools/firebase/sync-firebase-emulators.ts",
    "verify:firebase-emulators": "npx vitest run tests/unit/firebaseEmulatorConfigConsistency.test.ts",
    "verify:design-tokens": "node scripts/verify/verify-design-tokens.mjs",
    "build:verify-sw": "npm run build && npm run verify:sw",
    "typecheck": "npm exec tsc -- -p tsconfig.app.json --noEmit --pretty false --locale ja && npm exec tsc -- -p tsconfig.node.json --noEmit --pretty false --locale ja",
    "typecheck:test": "npm exec tsc -- -p tsconfig.test.json --noEmit --pretty false --locale ja",
    "typecheck:all": "npm exec tsc -- -p tsconfig.app.json --noEmit --pretty false --locale ja && npm exec tsc -- -p tsconfig.node.json --noEmit --pretty false --locale ja",
    "preflight": "npm run verify:design-tokens && npm run verify:app-icon && npm run verify:source-conventions && npm run typecheck && npm run build && npx vitest run tests/unit/parseXlsxImport.test.ts tests/unit/importCardsFromPayload.test.ts tests/unit/features/import/XlsxImportDialog.test.tsx tests/unit/platformIndex.test.ts tests/unit/platformDesktopShellOpenExternal.test.ts",
    "lint:imports": "npm run fix:source-conventions",
    "lint": "npm run lint:imports && node scripts/lint-eslint-ja.mjs && npm run verify:source-conventions",
    "lint:fix": "node scripts/lint-fix.mjs",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:codeblock": "playwright test tests/e2e/codeblock_visual.spec.ts",
    "test:e2e:card-layout": "playwright test tests/e2e/card_layout_consistency.spec.ts"
  },
