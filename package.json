{
  "name": "@sivflow/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/frontend/*",
    "packages/frontend/apps/*",
    "packages/backend/*",
    "packages/common/*",
    "blocksuite/**",
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "npmize": "node scripts/npmize-workspace-protocols.mjs",
    "lint": "npm run typecheck",
    "typecheck": "tsc --build packages/frontend/apps/web/tsconfig.json --pretty false",
    "db:check": "node scripts/check-local-services.mjs",
    "db:migrate": "node scripts/apply-postgres-migrations.mjs",
    "db:psql": "psql -h localhost -p 5432 -U sivflow -d sivflow",
    "dev": "npm --workspace @affine/web run dev",
    "dev:web": "npm --workspace @affine/web run dev",
    "dev:frontend": "npm --workspace @affine/web run dev",
    "dev:electron": "npm --workspace @affine/electron run dev",
    "dev:backend": "npm --workspace @affine/server run dev",
    "dev:backend:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-backend-local.ps1",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-backend-local.ps1",
    "dev:server": "npm --workspace @affine/server run dev",
    "build": "npm --workspace @affine/web run build",
    "build:web": "npm --workspace @affine/web run build",
    "build:frontend": "npm --workspace @affine/web run build",
    "build:backend": "npm --workspace @affine/server run build",
    "build:cloudrun": "npm --prefix functions run build:cloudrun",
    "deploy:cloudrun": "gcloud builds submit --config cloudbuild.yaml",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "admin:dev": "npm --workspace @affine/admin run dev",
    "admin:build": "npm --workspace @affine/admin run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "packageManager": "npm@10.9.0"
}
