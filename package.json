{
  "name": "@sivflow/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/frontend/*",
    "packages/frontend/apps/*",
    "packages/backend/*",
    "packages/common/*",
    "blocksuite/**",
    "tests/**",
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "22.20.0"
  },
  "scripts": {
    "npmize": "node scripts/npmize-workspace-protocols.mjs",
    "lint": "node scripts/lint-fix.mjs --check-only",
    "lint:fix": "node scripts/lint-fix.mjs",
    "verify:design-tokens": "node scripts/verify/verify-design-tokens.mjs",
    "verify:source-conventions": "node scripts/lint-fix.mjs --check-only",
    "fix:source-conventions": "node scripts/lint-fix.mjs --fixers-only",
    "typecheck": "tsc --build packages/frontend/apps/web/tsconfig.json --pretty false --noCheck",
    "typecheck:strict": "tsc --build packages/frontend/apps/web/tsconfig.json --pretty false",
    "check:nbstore-worker": "node scripts/assert-nbstore-worker-bundle.mjs",
    "check:nbstore-worker:source": "node scripts/assert-nbstore-worker-bundle.mjs --source-only",
    "test:backend": "npm --workspace @affine/server run test",
    "test:blocksuite": "npm --workspace @blocksuite/integration-test run test:unit",
    "test:blocksuite:debug": "npm --workspace @blocksuite/integration-test run test:debug",
    "db:check": "node scripts/check-local-services.mjs",
    "db:migrate": "node scripts/apply-postgres-migrations.mjs",
    "db:psql": "psql -h 127.0.0.1 -p 5432 -U sivflow -d sivflow",
    "dev": "node scripts/dev-web-backend.mjs",
    "dev:web": "node scripts/dev-web-backend.mjs",
    "dev:web:backend": "node scripts/dev-web-backend.mjs",
    "dev:web:only": "npm --workspace @affine/web run dev",
    "dev:frontend": "npm --workspace @affine/web run dev",
    "dev:electron": "npm --workspace @affine/electron run dev",
    "dev:backend": "npm --workspace @affine/server run dev",
    "dev:backend:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-backend-local.ps1",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-backend-local.ps1",
    "dev:server": "npm --workspace @affine/server run dev",
    "build": "npm --workspace @affine/web run build",
    "build:deploy": "npm --workspace @affine/templates run build && npm --workspace @affine/web run build:raw",
    "build:web": "npm --workspace @affine/web run build",
    "build:frontend": "npm --workspace @affine/web run build",
    "build:backend": "npm --workspace @affine/server run build",
    "build:cloudrun": "npm run build:backend",
    "deploy:cloudrun": "gcloud builds submit --config cloudbuild.yaml",
    "deploy:hosting": "npm run deploy:cloudrun && firebase deploy --only hosting",
    "deploy:hosting:only": "firebase deploy --only hosting",
    "admin:dev": "npm --workspace @affine/admin run dev",
    "admin:build": "npm --workspace @affine/admin run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "firebase": "^12.15.0",
    "lodash.includes": "^4.3.0",
    "lodash.isboolean": "^3.0.3",
    "lodash.isinteger": "^4.0.4",
    "lodash.isnumber": "^3.0.3",
    "lodash.isplainobject": "^4.0.6",
    "lodash.isstring": "^4.0.1",
    "lodash.once": "^4.1.1"
  }
}