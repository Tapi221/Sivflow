{
  "name": "flashcard-master",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite",
    "design-tokens:build": "npm exec tsx -- tools/design-tokens/build-tokens.ts",
    "dev:electron": "concurrently -k \"npm run dev:web\" \"npm run electron:watch\" \"npm run electron:dev\"",
    "electron:dev": "npm run electron:prepare-dist && wait-on tcp:5173 dist-electron/main.js dist-electron/preload.js && node scripts/electron/run-electron.cjs dist-electron/main.js --renderer-url=http://localhost:5173",
    "electron:prepare-dist": "node -e \"const fs=require('node:fs');fs.mkdirSync('dist-electron',{recursive:true});fs.writeFileSync('dist-electron/package.json', JSON.stringify({ type: 'commonjs' }, null, 2));\"",
    "electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "generate:icons:stratis": "node scripts/generate-stratis-icons.mjs",
    "build": "npm run build:web",
    "build:web": "node scripts/copy-pdfjs-assets.mjs && vite build",
    "build:electron": "npm run build:web && npm run electron:build",
    "electron:build": "tsc -p tsconfig.electron.json && npm run electron:prepare-dist",
    "electron:start": "node scripts/electron/run-electron.cjs dist-electron/main.js",
    "verify:icons": "node scripts/verify-icons-entry.mjs",
    "verify:sw": "node scripts/verify/verify-sw.mjs",
    "build:verify-sw": "npm run build && npm run verify:sw",
    "typecheck": "npm exec tsc -- -p tsconfig.app.json --noEmit --pretty false && npm exec tsc -- -p tsconfig.node.json --noEmit --pretty false",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs",
    "typecheck:test": "npm exec tsc -- -p tsconfig.test.json --noEmit --pretty false",
    "typecheck:all": "npm exec tsc -- -p tsconfig.app.json --noEmit --pretty false && npm exec tsc -- -p tsconfig.node.json --noEmit --pretty false && npm exec tsc -- -p tsconfig.electron.json --noEmit --pretty false",
    "preflight": "npm run typecheck && npm run build && npx vitest run tests/unit/pdfZoomUtils.test.ts tests/unit/parseXlsxImport.test.ts tests/unit/importCardsFromPayload.test.ts tests/unit/features/import/XlsxImportDialog.test.tsx tests/unit/platformIndex.test.ts tests/unit/platformDesktopShellOpenExternal.test.ts tests/unit/signInWithGoogleUseCase.test.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e:codeblock": "playwright test tests/e2e/codeblock_visual.spec.ts",
    "test:e2e:card-layout": "playwright test tests/e2e/card_layout_consistency.spec.ts",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.17",
    "autoprefixer": "^10.4.23",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "dompurify": "^3.3.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^12.29.2",
    "heic2any": "^0.0.4",
    "katex": "^0.16.28",
    "nanoid": "^5.1.6",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8.5.6",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-simple-code-editor": "^0.14.1",
    "react-spring": "^10.0.3",
    "recharts": "^3.6.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "turndown": "^7.2.2",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "fast-glob": "^3.3.3",
    "firebase-tools": "^15.12.0",
    "globals": "^16.5.0",
    "jscodeshift": "^17.3.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
