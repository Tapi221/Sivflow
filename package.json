{
  "name": "@sivflow/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/frontend/*",
    "packages/frontend/apps/*",
    "packages/backend/*",
    "packages/common/*",
    "blocksuite/**",
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "npmize": "node scripts/npmize-workspace-protocols.mjs",
    "lint": "npm run typecheck",
    "typecheck": "tsc --project packages/frontend/apps/web/tsconfig.json --pretty false",
    "db:up": "docker compose -f docker-compose.postgres.yml up -d",
    "db:down": "docker compose -f docker-compose.postgres.yml down",
    "db:reset": "docker compose -f docker-compose.postgres.yml down -v && docker compose -f docker-compose.postgres.yml up -d",
    "db:psql": "docker compose -f docker-compose.postgres.yml exec postgres psql -U sivflow -d sivflow",
    "dev": "npm --workspace @affine/web run dev",
    "dev:web": "npm --workspace @affine/web run dev",
    "dev:frontend": "npm --workspace @affine/web run dev",
    "dev:backend": "npm --workspace @affine/server run dev",
    "dev:server": "npm --workspace @affine/server run dev",
    "build": "npm --workspace @affine/web run build",
    "build:web": "npm --workspace @affine/web run build",
    "build:frontend": "npm --workspace @affine/web run build",
    "build:backend": "npm --workspace @affine/server run build",
    "build:cloudrun": "docker build -f Dockerfile.cloudrun -t sivflow-api .",
    "deploy:cloudrun": "gcloud builds submit --config cloudbuild.yaml",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "admin:dev": "npm --workspace @affine/admin run dev",
    "admin:build": "npm --workspace @affine/admin run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "packageManager": "npm@10.9.0"
}
